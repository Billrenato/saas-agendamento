

# ============================================
# BANCO DE DADOS
# ============================================
DATABASE_URL=

# ============================================
# JWT (AUTENTICAÇÃO) - CHAVE GERADA!
# ============================================
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# AMBIENTE
# ============================================
ENVIRONMENT=development

# ============================================
# CORS (para desenvolvimento)
# ============================================
ALLOWED_ORIGINS=

# ============================================
# TWILIO (WhatsApp) - cada empresa usa as suas
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ============================================
# UPLOAD
# ============================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880